# {{ domain.name }} Context Graph Application
# Generated by create-context-graph

-include .env
export

.PHONY: start dev dev-backend dev-frontend install seed reset clean test test-e2e lint docker-build docker-prod-up docker-prod-down

# Start both backend and frontend
start:
	@echo "Starting {{ domain.name }} Context Graph..."
	@trap 'kill 0' EXIT; \
		$(MAKE) dev-backend & \
		$(MAKE) dev-frontend & \
		wait

dev: start

# Backend
dev-backend:
{% if framework in ['crewai', 'strands', 'google-adk'] %}
	cd backend && uv run uvicorn app.main:app --reload --port $${BACKEND_PORT:-8000} --loop asyncio
{% else %}
	cd backend && uv run uvicorn app.main:app --reload --port $${BACKEND_PORT:-8000}
{% endif %}

install-backend:
	cd backend && uv sync
	cd backend && uv run python -m spacy download en_core_web_sm

# Frontend
dev-frontend:
	cd frontend && NEXT_PUBLIC_API_URL=http://localhost:$${BACKEND_PORT:-8000}/api npm run dev -- --port $${FRONTEND_PORT:-3000}

install-frontend:
	cd frontend && npm install

# Install everything
install: install-backend install-frontend

# Seed data into Neo4j
seed:
	cd backend && uv run python scripts/generate_data.py

# Reset Neo4j data (drop and recreate)
reset:
	cd backend && uv run python -c "from app.context_graph_client import reset_database; import asyncio; asyncio.run(reset_database())"

{% if neo4j_type == 'docker' %}
# Docker Neo4j
docker-up:
	docker compose up -d

docker-down:
	docker compose down
{% endif %}

{% if neo4j_type == 'local' %}
# Local Neo4j (no Docker required)
neo4j-start:
	@echo "Starting Neo4j in background..."
	@npx --yes @johnymontana/neo4j-local start > /tmp/neo4j-local.log 2>&1 & \
		sleep 2 && npx --yes @johnymontana/neo4j-local status

neo4j-stop:
	npx --yes @johnymontana/neo4j-local stop

neo4j-status:
	npx --yes @johnymontana/neo4j-local status
{% endif %}

{% if saas_connectors %}
# Data import from connected services
import:
	cd backend && uv run python scripts/import_data.py

import-and-seed: import
	cd backend && uv run python scripts/generate_data.py --ingest
{% endif %}

# Test
test:
	cd backend && uv run python -m pytest tests/ -v 2>/dev/null || echo "No backend tests found"
	cd frontend && npm test 2>/dev/null || echo "No frontend tests found"

# End-to-end tests (requires backend + frontend running, and Playwright installed)
test-e2e:
	cd frontend && npx playwright install --with-deps chromium 2>/dev/null; npm run test:e2e

# Lint
lint:
	cd backend && uv run ruff check app/ 2>/dev/null || echo "Install ruff for linting: uv pip install ruff"
	cd frontend && npm run lint 2>/dev/null || echo "No frontend lint configured"

# Docker production deployment
docker-build:
	docker compose -f docker-compose.prod.yml build

docker-prod-up:
	docker compose -f docker-compose.prod.yml up -d

docker-prod-down:
	docker compose -f docker-compose.prod.yml down

# Clean build artifacts
clean:
	rm -rf backend/__pycache__ backend/.venv
	rm -rf frontend/.next frontend/node_modules
