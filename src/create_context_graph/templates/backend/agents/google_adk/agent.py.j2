"""{{ domain.name }} AI Agent — Google ADK implementation."""

from __future__ import annotations

import asyncio
import json
import uuid

# Google ADK calls sync tool functions from within its async run_async() loop,
# requiring nest_asyncio to bridge sync tools back to async execute_cypher().
import nest_asyncio
if not getattr(asyncio, "_nest_patched", False):
    nest_asyncio.apply()

from google.adk.agents import Agent
from google.adk.tools import FunctionTool

from app.config import settings
from app.context_graph_client import (
    execute_cypher, get_schema,
    get_conversation_history, store_message, get_collector,
)


def _run_sync(coro):
    """Run an async coroutine from a synchronous context.

    Prefers asyncio.run() when no event loop is running (worker threads).
    Falls back to nest_asyncio-patched loop.run_until_complete() when
    called from within ADK's async run_async() context.
    """
    try:
        loop = asyncio.get_running_loop()
    except RuntimeError:
        return asyncio.run(coro)
    return loop.run_until_complete(coro)


SYSTEM_PROMPT = """{{ system_prompt }}"""

