# ---------------------------------------------------------------------------
# Modular tool registry for {{ endraw }}{{ domain.name }}{% raw %}
# ---------------------------------------------------------------------------

TOOL_REGISTRY = {}


def register_tool(name: str, description: str):
    """Decorator to register a tool function."""
    def decorator(func):
        TOOL_REGISTRY[name] = {"function": func, "description": description}
        return func
    return decorator
