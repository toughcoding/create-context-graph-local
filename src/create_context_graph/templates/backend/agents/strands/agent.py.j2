"""{{ domain.name }} AI Agent — Strands (AWS) implementation."""

from __future__ import annotations

import json
import uuid

import nest_asyncio
nest_asyncio.apply()

from strands import Agent
from strands.tools import tool

from app.config import settings
from app.context_graph_client import (
    execute_cypher, search_entities, get_entity_graph, get_schema,
    get_conversation_history, store_message,
)


SYSTEM_PROMPT = """{{ system_prompt }}"""

# ---------------------------------------------------------------------------
# Agent tools — domain-specific for {{ domain.name }}
# ---------------------------------------------------------------------------

{% for tool in agent_tools %}
@tool
def {{ tool.name }}({% for param in tool.parameters %}{{ param.name }}: {{ 'str' if param.type == 'string' else 'int' if param.type == 'integer' else 'float' if param.type == 'float' else 'str' }}{% if param.default is not none %} = {{ param.default if param.type != 'string' else '"' + param.default + '"' }}{% endif %}{% if not loop.last %}, {% endif %}{% endfor %}) -> str:
    """{{ tool.description }}"""
    import asyncio
    cypher = """{{ tool.cypher | indent(4) }}"""
    params = {
{% for param in tool.parameters %}
        "{{ param.name }}": {{ param.name }},
{% endfor %}
    }
    result = asyncio.run(execute_cypher(cypher, params, tool_name="{{ tool.name }}"))
    return json.dumps(result, default=str)

{% endfor %}

{% raw %}
@tool
def run_cypher(query: str, parameters: str = "{}") -> str:
    """Execute a read-only Cypher query against the knowledge graph."""
    import asyncio
    try:
        params = json.loads(parameters) if parameters else {}
    except json.JSONDecodeError:
        return json.dumps({"error": "Invalid JSON parameters"})
    result = asyncio.run(execute_cypher(query, params, tool_name="run_cypher"))
    return json.dumps(result, default=str)


@tool
def get_graph_schema() -> str:
    """Get the knowledge graph schema (node labels and relationship types)."""
    import asyncio
    result = asyncio.run(get_schema())
    return json.dumps(result, default=str)
{% endraw %}

agent = Agent(
    system_prompt=SYSTEM_PROMPT,
    tools=[
{% for tool in agent_tools %}
        {{ tool.name }},
{% endfor %}
        run_cypher,
        get_graph_schema,
    ],
)

{% raw %}
# ---------------------------------------------------------------------------
# Message handler
# ---------------------------------------------------------------------------


async def handle_message(message: str, session_id: str | None = None) -> dict:
    """Handle an incoming chat message."""
    if session_id is None:
        session_id = str(uuid.uuid4())

    # Retrieve conversation history and store the new user message
    history = await get_conversation_history(session_id)
    await store_message(session_id, "user", message)

    # Build message with conversation context
    if history:
        context = "\n".join(
            f"{'User' if m['role'] == 'user' else 'Assistant'}: {m['content']}"
            for m in history
        )
        input_message = (
            f"Previous conversation:\n{context}\n\n"
            f"Current question: {message}"
        )
    else:
        input_message = message

    result = agent(input_message)

    response_text = str(result)
    await store_message(session_id, "assistant", response_text)

    return {
        "response": response_text,
        "session_id": session_id,
        "graph_data": None,
    }
{% endraw %}
