[project]
name = "{{ project_slug }}-backend"
version = "0.1.0"
description = "{{ domain.name }} Context Graph Backend"
{% if framework == 'crewai' %}requires-python = ">=3.11"{% else %}requires-python = ">=3.10"{% endif %}
dependencies = [
    "fastapi>=0.115",
    "uvicorn[standard]>=0.30",
    "pydantic>=2.0",
    "pydantic-settings>=2.0",
    "neo4j>=5.20",
    "neo4j-agent-memory[spacy,gliner]>=0.0.5",
{% for dep in framework_deps %}
    "{{ dep }}",
{% endfor %}
]

[tool.hatch.build.targets.wheel]
packages = ["app"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
