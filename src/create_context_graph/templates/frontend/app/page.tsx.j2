{% raw %}"use client";

import { useState, useCallback } from "react";
import { Box, Flex, Heading, Text, Tabs } from "@chakra-ui/react";
import dynamic from "next/dynamic";
import { ChatInterface } from "@/components/ChatInterface";
const ContextGraphView = dynamic(
  () => import("@/components/ContextGraphView").then((mod) => mod.ContextGraphView),
  { ssr: false }
);
import { DecisionTracePanel } from "@/components/DecisionTracePanel";
import { DocumentBrowser } from "@/components/DocumentBrowser";
import { DOMAIN } from "@/lib/config";
import type { GraphData } from "@/lib/config";

export default function Home() {
  const [graphData, setGraphData] = useState<GraphData | null>(null);

  const handleGraphUpdate = useCallback((data: GraphData) => {
    setGraphData(data);
  }, []);

  return (
    <Flex direction="column" h="100vh">
      {/* Header */}
      <Box bg="gray.900" color="white" px={6} py={3}>
        <Heading size="md">
          {% endraw %}{{ domain.emoji }}{% raw %} {DOMAIN.name} Context Graph
        </Heading>
        <Text fontSize="sm" color="gray.400">
          {DOMAIN.tagline}
        </Text>
      </Box>

      {/* Main content - 3 panel layout */}
      <Flex as="main" flex={1} overflow="hidden">
        {/* Left panel: Chat */}
        <Box as="section" aria-label="Chat" w="400px" borderRight="1px solid" borderColor="gray.200" overflow="auto">
          <ChatInterface onGraphUpdate={handleGraphUpdate} />
        </Box>

        {/* Center panel: Graph visualization */}
        <Box as="section" aria-label="Graph visualization" flex={1} bg="gray.50">
          <ContextGraphView externalGraphData={graphData} />
        </Box>

        {/* Right panel: Decision traces + Documents */}
        <Box as="aside" aria-label="Details" w="350px" borderLeft="1px solid" borderColor="gray.200" overflow="hidden">
          <Tabs.Root defaultValue="traces" size="sm">
            <Tabs.List borderBottom="1px solid" borderColor="gray.200">
              <Tabs.Trigger value="traces">Traces</Tabs.Trigger>
              <Tabs.Trigger value="documents">Documents</Tabs.Trigger>
            </Tabs.List>
            <Tabs.Content value="traces" p={0} h="calc(100vh - 110px)" overflow="auto">
              <DecisionTracePanel />
            </Tabs.Content>
            <Tabs.Content value="documents" p={0} h="calc(100vh - 110px)" overflow="auto">
              <DocumentBrowser />
            </Tabs.Content>
          </Tabs.Root>
        </Box>
      </Flex>
    </Flex>
  );
}
{% endraw %}
